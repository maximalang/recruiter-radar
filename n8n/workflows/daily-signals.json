{
  "name": "My workflow",
  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH picked AS (\n  SELECT\n    l.id::text AS lead_id,\n    l.id,\n    l.user_id,\n    o.name AS org_name,\n    l.status::text AS status,\n    l.score,\n    COALESCE(NULLIF(u.full_name, ''), u.email) AS user_name,\n    l.last_signal_at\n  FROM leads l\n  JOIN orgs o ON o.id = l.org_id\n  JOIN users u ON u.id = l.user_id\n  LEFT JOIN sent_leads s ON s.lead_id = l.id::text\n  WHERE l.status::text IN ('new', 'contacted', 'replied')\n    AND s.lead_id IS NULL\n  ORDER BY l.score DESC NULLS LAST, l.last_signal_at DESC NULLS LAST\n  LIMIT 3\n),\ninserted AS (\n  INSERT INTO sent_leads (lead_id)\n  SELECT lead_id\n  FROM picked\n  ON CONFLICT (lead_id) DO NOTHING\n  RETURNING lead_id\n)\nSELECT\n  p.id,\n  p.org_name,\n  p.status,\n  p.score,\n  p.user_name\nFROM picked p\nJOIN inserted i ON i.lead_id = p.lead_id\nORDER BY p.score DESC NULLS LAST, p.last_signal_at DESC NULLS LAST;",
        "options": {}
      },
