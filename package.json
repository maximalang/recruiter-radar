{
  "name": "recruiter-radar",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @recruiter-radar/web",
    "clean": "node scripts/clean.mjs",
    "db:validate": "npm run validate --workspace @recruiter-radar/db",
    "web:build": "npm run build --workspace @recruiter-radar/web",
    "web:check": "npm run check --workspace @recruiter-radar/web",
    "web:validate": "npm run validate --workspace @recruiter-radar/web",
    "source:list": "node packages/db/scripts/run-source-action.mjs list",
    "source:fetch": "npm run source:fetch:primary",
    "source:fetch:primary": "npm run source:fetch:hh",
    "source:fetch:hh": "node packages/db/scripts/run-source-action.mjs fetch hh",
    "source:fetch:career-pages": "node packages/db/scripts/run-source-action.mjs fetch career-pages",
    "source:ingest": "npm run source:ingest:primary",
    "source:ingest:primary": "npm run source:ingest:hh",
    "source:ingest:hh": "node packages/db/scripts/run-source-action.mjs ingest hh",
    "source:ingest:career-pages": "node packages/db/scripts/run-source-action.mjs ingest career-pages",
    "source:report": "npm run hh:report",
    "source:metrics": "npm run hh:metrics",
    "source:score": "npm run hh:score",
    "source:top": "npm run hh:top",
    "source:why-now": "npm run hh:why-now",
    "source:opener": "npm run hh:opener",
    "source:digest": "npm run hh:digest",
    "source:run": "npm run source:pipeline:primary",
    "source:pipeline": "npm run source:pipeline:primary",
    "source:pipeline:primary": "npm run source:pipeline:hh",
    "source:pipeline:hh": "node packages/db/scripts/run-source-action.mjs pipeline hh",
    "source:pipeline:career-pages": "node packages/db/scripts/run-source-action.mjs pipeline career-pages",
    "career-pages:smoke": "CAREER_PAGES_TARGETS_FILE=packages/db/scripts/career-pages-smoke-targets.json node packages/db/scripts/source-career-pages.mjs fetch",
    "verify:career-pages:smoke": "node packages/db/scripts/verify-career-pages-smoke.mjs",
    "verify:career-pages:discovery": "node packages/db/scripts/verify-career-pages-discovery-smoke.mjs",
    "verify:career-pages:ingest": "node packages/db/scripts/verify-career-pages-ingest.mjs",
    "verify:digest:feedback": "node packages/db/scripts/verify-digest-feedback-smoke.mjs",
    "verify:digest:selection": "node packages/db/scripts/verify-digest-selection-smoke.mjs",
    "verify:mixed-ranking": "node packages/db/scripts/verify-mixed-ranking-smoke.mjs",
    "verify:smoke": "node packages/db/scripts/verify-smoke.mjs",
    "hh:fetch": "npm run source:fetch:hh",
    "hh:ingest": "npm run source:ingest:hh",
    "hh:report": "node packages/db/scripts/report-hh-orgs.mjs",
    "hh:metrics": "node packages/db/scripts/report-hh-metrics.mjs",
    "hh:score": "node packages/db/scripts/report-hh-score.mjs",
    "hh:top": "node packages/db/scripts/report-hh-top.mjs",
    "hh:why-now": "node packages/db/scripts/report-hh-why-now.mjs",
    "hh:opener": "node packages/db/scripts/report-hh-opener.mjs",
    "hh:digest": "node packages/db/scripts/report-hh-digest.mjs",
    "hh:pipeline": "node packages/db/scripts/run-source-action.mjs pipeline hh",
    "digest:held": "node packages/db/scripts/report-digest-held.mjs"
  }
}
